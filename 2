#include "client-render/world.h"
#include "client-render/scene.h"
#include "client-render/texture.h"
#include "core/vector.h"

void R_Block_MakeFacePolys(struct R_PolyVec *vec, struct R_Block *block,
                           enum R_Face face, ivec3_t block_pos) {
    float x = block_pos.x;
    float y = block_pos.y;
    float z = block_pos.z;

    vec3_t v0, v1, v2, v3;

    switch (face) {
    case R_FACE_TOP:
        v0 = (vec3_t){x, y + 1.0f, z};
        v1 = (vec3_t){x + 1.0f, y + 1.0f, z};
        v2 = (vec3_t){x + 1.0f, y + 1.0f, z + 1.0f};
        v3 = (vec3_t){x, y + 1.0f, z + 1.0f};
        break;

    case R_FACE_BOTTOM:
        v0 = (vec3_t){x, y, z + 1.0f};
        v1 = (vec3_t){x + 1.0f, y, z + 1.0f};
        v2 = (vec3_t){x + 1.0f, y, z};
        v3 = (vec3_t){x, y, z};
        break;

    case R_FACE_PP:
        v0 = (vec3_t){x + 1.0f, y, z};
        v1 = (vec3_t){x + 1.0f, y, z + 1.0f};
        v2 = (vec3_t){x + 1.0f, y + 1.0f, z + 1.0f};
        v3 = (vec3_t){x + 1.0f, y + 1.0f, z};
        break;

    case R_FACE_PN:
        v0 = (vec3_t){x + 1.0f, y, z + 1.0f};
        v1 = (vec3_t){x, y, z + 1.0f};
        v2 = (vec3_t){x, y + 1.0f, z + 1.0f};
        v3 = (vec3_t){x + 1.0f, y + 1.0f, z + 1.0f};
        break;

    case R_FACE_NP:
        v0 = (vec3_t){x, y, z + 1.0f};
        v1 = (vec3_t){x, y, z};
        v2 = (vec3_t){x, y + 1.0f, z};
        v3 = (vec3_t){x, y + 1.0f, z + 1.0f};
        break;

    case R_FACE_NN:
        v0 = (vec3_t){x, y, z};
        v1 = (vec3_t){x + 1.0f, y, z};
        v2 = (vec3_t){x + 1.0f, y + 1.0f, z};
        v3 = (vec3_t){x, y + 1.0f, z};
        break;
    }

    tvec2_t uv0 = (tvec2_t){0.0f, 0.0f};
    tvec2_t uv1 = (tvec2_t){1.0f, 0.0f};
    tvec2_t uv2 = (tvec2_t){1.0f, 1.0f};
    tvec2_t uv3 = (tvec2_t){0.0f, 1.0f};

    struct R_Triangle t1 = {0};
    t1.texture = &block->faces->face[face];
    t1.v[0] = v0;
    t1.v[1] = v1;
    t1.v[2] = v2;
    t1.t[0] = uv0;
    t1.t[1] = uv1;
    t1.t[2] = uv2;

    struct R_Triangle t2 = {0};
    t2.texture = &block->faces->face[face];
    t2.v[0] = v0;
    t2.v[1] = v2;
    t2.v[2] = v3;
    t2.t[0] = uv0;
    t2.t[1] = uv2;
    t2.t[2] = uv3;

    R_PolyVec_Push(vec, &t1);
    R_PolyVec_Push(vec, &t2);
}

const ivec3_t FACE_OFFSET_MAP[6] = {
    [R_FACE_TOP] = {0, 0, 0},
};

void R_Chunk_MakeBlockFaces(struct R_PolyVec *vec, const struct R_Chunk *chunk) {
    for (int x = 0; x < 16; ++x) {
        for (int z = 0; z < 16; ++z) {
            for (int y = 0; y < 16; ++y) {
                struct R_Block *b = &chunk->data->blocks[x][y][z];
                if (b->block_type == R_BTYPE_AIR)
                    continue;
                for (int i = 0; i < 6; ++i) {
                    return;
                }
            }
        }
    }
}
